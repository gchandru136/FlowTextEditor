{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    /* Required because this project is referenced by tsconfig.json */
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",

    /* Browser code must not depend on ambient Node globals */
    "types": [],

    /* Path aliases (mirrored in the Vite configs). No `baseUrl` — it is
       deprecated in TS; `paths` resolve relative to this config's directory. */
    "paths": {
      "emailrichtexteditor": ["./src/index.ts"],
      "@/*": ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@utils/*": ["./src/utils/*"],
      "@styles/*": ["./src/styles/*"],
      "@assets/*": ["./src/assets/*"]
    },

    /* Vite owns emit; tsc is used only for type-checking */
    "noEmit": true
  },
  "include": ["src", "playground/src"]
}
